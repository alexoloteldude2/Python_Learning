# ──────────────────────────────────────────────────────────────
# PSLE Planner — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (server-side only — never expose to browser)
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Authentication ────────────────────────────────────────────
# The global password users must enter on the login page
APP_PASSWORD=your_secret_password_here

# A random string used to sign the session cookie.
# Generate one: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars
